{
  "name": "gdinvoices",
  "version": "1.0.0",
  "description": "GoDaddy Invoice Downloader - Automates downloading GoDaddy receipt PDFs",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "node scripts/wait-for-vite.js && tsc -p tsconfig.main.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "pack": "npm run build && electron-builder --win --dir"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.gdinvoices.app",
    "productName": "GDInvoices",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "asar": true
  }
}
